<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="LoginButtonStyle">
        <item name="android:backgroundTint">@color/skyblue</item>
        <item name="android:textColor">@color/blue_dark</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="LoginSignInStyle">
        <item name="android:backgroundTint">@color/blue_dark</item>
        <item name="android:textColor">@color/blue_light</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="PopupMenuStyle">

        <!-- Fondo transparente -->
        <item name="android:popupBackground">
            @android:color/transparent
        </item>

        <!-- Fondo de cada item -->
        <item name="android:itemBackground">
            @drawable/menu_item_background
        </item>

        <!-- Color del texto -->
        <item name="android:textColor">
            @color/menu_text_color
        </item>

    </style>
</resources>