<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- CONTENIDO DISEÑO -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F8F8F8"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- TOOLBAR -->
            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:background="#42C4F7"
                app:title="Registrar Carnet"
                app:titleTextColor="@android:color/white"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- CARD PERFIL -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPerfil"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp"
                app:layout_constraintTop_toBottomOf="@id/toolbar"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/txtNombre"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Daniela Fernanda Morales Corea"
                        android:textColor="@color/blue_dark"
                        android:textStyle="bold"
                        android:textSize="16sp"/>

                    <TextView
                        android:id="@+id/txtEdad"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="21 años y 4 meses"
                        android:textColor="#B0B0B0"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══════════════════════════════════════
                 CARD FOTOS
            ══════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardFotos"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp"
                app:layout_constraintTop_toBottomOf="@id/cardPerfil"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Título sección -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FOTOS DEL CARNET"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/skyblue"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="12dp"/>

                    <!-- Fila de fotos -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2"
                        android:gravity="center">

                        <!-- Foto frontal -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:layout_marginEnd="6dp">

                            <FrameLayout
                                android:id="@+id/btnFotoFrontal"
                                android:layout_width="match_parent"
                                android:layout_height="110dp"
                                android:background="@drawable/bg_foto_dashed"
                                android:clickable="true"
                                android:focusable="true">

                                <!-- Preview de imagen (oculto hasta que se elige) -->
                                <ImageView
                                    android:id="@+id/imgFrontal"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:scaleType="centerCrop"
                                    android:visibility="gone"/>

                                <!-- Placeholder visible antes de elegir -->
                                <LinearLayout
                                    android:id="@+id/placeholderFrontal"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:orientation="vertical"
                                    android:gravity="center">

                                    <ImageView
                                        android:layout_width="32dp"
                                        android:layout_height="32dp"
                                        android:src="@drawable/outline_camera_24"
                                        app:tint="@color/blue"/>

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Parte frontal"
                                        android:textSize="11sp"
                                        android:textColor="@color/skyblue"
                                        android:textStyle="bold"
                                        android:layout_marginTop="6dp"/>

                                </LinearLayout>
                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Anverso"
                                android:textSize="10sp"
                                android:textColor="#AAAAAA"
                                android:layout_marginTop="5dp"/>

                        </LinearLayout>

                        <!-- Foto trasera -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:layout_marginStart="6dp">

                            <FrameLayout
                                android:id="@+id/btnFotoTrasera"
                                android:layout_width="match_parent"
                                android:layout_height="110dp"
                                android:background="@drawable/bg_foto_dashed"
                                android:clickable="true"
                                android:focusable="true">

                                <ImageView
                                    android:id="@+id/imgTrasera"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:scaleType="centerCrop"
                                    android:visibility="gone"/>

                                <LinearLayout
                                    android:id="@+id/placeholderTrasera"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:orientation="vertical"
                                    android:gravity="center">

                                    <ImageView
                                        android:layout_width="32dp"
                                        android:layout_height="32dp"
                                        android:src="@drawable/outline_camera_24"
                                        app:tint="@color/blue"/>

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Parte trasera"
                                        android:textSize="11sp"
                                        android:textColor="@color/skyblue"
                                        android:textStyle="bold"
                                        android:layout_marginTop="6dp"/>

                                </LinearLayout>
                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Reverso"
                                android:textSize="10sp"
                                android:textColor="#AAAAAA"
                                android:layout_marginTop="5dp"/>

                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══════════════════════════════════════
                 CARD DATOS
            ══════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDatos"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp"
                app:layout_constraintTop_toBottomOf="@id/cardFotos"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DATOS DEL CARNET"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/skyblue"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="14dp"/>

                    <!-- Nombre propietario -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nombre del propietario"
                        android:textSize="11sp"
                        android:textColor="#888888"
                        android:layout_marginBottom="4dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxCornerRadiusTopStart="10dp"
                        app:boxCornerRadiusTopEnd="10dp"
                        app:boxCornerRadiusBottomStart="10dp"
                        app:boxCornerRadiusBottomEnd="10dp"
                        app:boxStrokeColor="@color/blue_light"
                        app:hintTextColor="@color/skyblue">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etNombrePropietario"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Ej. Daniela Morales Corea"
                            android:inputType="textPersonName"
                            android:textSize="13sp"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Clínica -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Clínica / Hospital"
                        android:textSize="11sp"
                        android:textColor="#888888"
                        android:layout_marginBottom="4dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxCornerRadiusTopStart="10dp"
                        app:boxCornerRadiusTopEnd="10dp"
                        app:boxCornerRadiusBottomStart="10dp"
                        app:boxCornerRadiusBottomEnd="10dp"
                        app:boxStrokeColor="@color/blue_light"
                        app:hintTextColor="@color/skyblue">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etClinica"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Ej. Hospital Nacional Rosales"
                            android:inputType="textCapWords"
                            android:textSize="13sp"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Fecha de registro -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fecha de registro"
                        android:textSize="11sp"
                        android:textColor="#888888"
                        android:layout_marginBottom="4dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxCornerRadiusTopStart="10dp"
                        app:boxCornerRadiusTopEnd="10dp"
                        app:boxCornerRadiusBottomStart="10dp"
                        app:boxCornerRadiusBottomEnd="10dp"
                        app:boxStrokeColor="@color/blue_light"
                        app:hintTextColor="@color/skyblue"
                        app:endIconMode="custom"
                        app:endIconDrawable="@drawable/outline_calendar_month_24"
                        app:endIconTint="@color/skyblue">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etFecha"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="DD/MM/AAAA"
                            android:inputType="none"
                            android:focusable="false"
                            android:textSize="13sp"/>

                    </com.google.android.material.textfield.TextInputLayout>


                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- BOTÓN GUARDAR -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGuardar"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="24dp"
                android:text="Guardar carnet"
                android:textSize="15sp"
                android:textColor="@android:color/white"
                app:backgroundTint="@color/blue"
                app:cornerRadius="14dp"
                app:layout_constraintTop_toBottomOf="@id/cardDatos"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- MENU HAMBURGUESA -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:menu="@menu/menu_drawer"
        app:headerLayout="@layout/header_drawer"/>

</androidx.drawerlayout.widget.DrawerLayout>