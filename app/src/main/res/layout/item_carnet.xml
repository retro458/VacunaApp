<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="14dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@android:color/white"
    app:strokeWidth="1dp"
    app:strokeColor="#ddeef8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Ícono del carnet -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/blue_light"
            app:cardElevation="0dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/outline_cards_stack_24"
                app:tint="@color/blue"
                android:contentDescription="Ícono carnet"/>

        </com.google.android.material.card.MaterialCardView>

        <!-- Textos -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <!-- Nombre de la clínica -->
            <TextView
                android:id="@+id/tvClinica"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hospital Nacional Rosales"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1a1a1a"
                android:maxLines="1"
                android:ellipsize="end"/>

            <!-- Propietario del carnet -->
            <TextView
                android:id="@+id/tvNombrePropietario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Daniela Morales Corea"
                android:textSize="11sp"
                android:textColor="@color/skyblue"
                android:layout_marginTop="2dp"/>

            <!-- Fecha con ícono -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="3dp">

                <ImageView
                    android:layout_width="11dp"
                    android:layout_height="11dp"
                    android:src="@drawable/outline_calendar_month_24"
                    app:tint="#AAAAAA"
                    android:contentDescription="Fecha"/>

                <TextView
                    android:id="@+id/tvFecha"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Registrado: 15/03/2024"
                    android:textSize="10sp"
                    android:textColor="#AAAAAA"
                    android:layout_marginStart="4dp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Flecha derecha -->
        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/outline_arrow_right_24"
            app:tint="@color/blue_light"
            android:layout_marginStart="8dp"
            android:contentDescription="Ver detalle"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>