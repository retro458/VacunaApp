<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F7FB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- TOOLBAR -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:background="@color/skyblue"
            app:title="Agendar Vacuna"
            app:titleTextColor="@android:color/white"/>

        <!-- CARD VACUNA -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Información de Vacuna"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="@color/blue_dark"
                    android:layout_marginBottom="16dp"/>

                <!-- SPINNER VACUNAS -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vacuna"
                    android:textStyle="bold"
                    android:textColor="@color/blue_dark"/>

                <Spinner
                    android:id="@+id/spVacunas"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/bg_spinnerv"/>

                <!-- SPINNER CENTROS -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Centro de Vacunación"
                    android:textStyle="bold"
                    android:textColor="@color/blue_dark"/>

                <Spinner
                    android:id="@+id/spCentros"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/bg_spinnerv"/>

                <!-- FECHA -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Fecha aplicación"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopStart="14dp"
                    app:boxCornerRadiusTopEnd="14dp"
                    app:boxCornerRadiusBottomStart="14dp"
                    app:boxCornerRadiusBottomEnd="14dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etFechaAplicacion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:focusable="false"/>

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- CARD DOSIS -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dosis"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="@color/blue_dark"
                    android:layout_marginBottom="16dp"/>

                <!-- DOSIS NUMERO -->
                <Spinner
                    android:id="@+id/spDosisNumero"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/bg_spinnerv"/>

                <!-- TOTAL DOSIS -->
                <Spinner
                    android:id="@+id/spTotalDosis"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/bg_spinnerv"/>

                <!-- ML -->
                <Spinner
                    android:id="@+id/spMl"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:background="@drawable/bg_spinnerv"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- CARD MEDICO -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Nombre del médico">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etMedico"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- BOTONES -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="30dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelar"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="Cancelar"
                android:textColor="@color/skyblue"
                android:backgroundTint="@android:color/white"
                app:strokeColor="@color/skyblue"
                app:strokeWidth="1dp"
                app:cornerRadius="25dp"/>

            <Space
                android:layout_width="12dp"
                android:layout_height="wrap_content"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGuardar"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="Guardar"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/skyblue"
                app:cornerRadius="25dp"/>

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>