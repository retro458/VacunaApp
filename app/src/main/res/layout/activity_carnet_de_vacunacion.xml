<?xml version="1.0" encoding="utf-8"?>

<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F8F8"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- HEADER -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:background="#42C4F7"
            app:title="CARNET DE VACUNACIÓN"
            app:titleTextColor="@android:color/white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- CARD PERFIL -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardPerfil"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/toolbar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/txtNombre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Daniela Fernanda Morales Corea"
                    android:textColor="#F4436C"
                    android:textStyle="bold"
                    android:textSize="16sp"/>

                <TextView
                    android:id="@+id/txtEdad"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="21 años y 4 meses"
                    android:textColor="#B0B0B0"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ESQUEMA DE GOBIERNO-->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardEsquemaGobierno"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/cardPerfil"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Esquema de Gobierno"
                    android:textColor="#FF5C8A"
                    android:textStyle="bold"
                    android:textSize="15sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mujeres de 20 a 59 años"
                    android:textColor="#FFB0C4"
                    android:textSize="13sp"
                    android:layout_marginBottom="12dp"/>

                <!-- Recycler Vacunas -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvVacunas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    tools:listitem="@layout/item_vacuna"/>

            </LinearLayout>


        </com.google.android.material.card.MaterialCardView>

        <!-- GRAFICA -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardGrafica"
            android:layout_width="0dp"
            android:layout_height="250dp"
            android:layout_margin="16dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/cardEsquemaGobierno"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/pieChart"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>

        </com.google.android.material.card.MaterialCardView>

        <!-- ESQUEMA COMPLEMENTARIO-->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardEsquemaComplementario"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/cardPerfil"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Esquema Complementario"
                    android:textColor="#FF5C8A"
                    android:textStyle="bold"
                    android:textSize="15sp"/>


                <!-- Recycler Vacunas -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvVacunasComplementarias"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    tools:listitem="@layout/item_vacuna"/>

            </LinearLayout>




        </com.google.android.material.card.MaterialCardView>

        <!-- GRAFICA -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardGraficaComplementario"
            android:layout_width="0dp"
            android:layout_height="250dp"
            android:layout_margin="16dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/cardEsquemaComplementario"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/pieChart2"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>

        </com.google.android.material.card.MaterialCardView>

        <!-- ESQUEMA COMPLEMENTARIO-->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardEsquemaIMC"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/cardPerfil"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IMC"
                    android:textColor="#FF5C8A"
                    android:textStyle="bold"
                    android:textSize="15sp"/>


                <!-- Recycler Vacunas -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvIMCRegistros"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    tools:listitem="@layout/item_vacuna"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- BOTONES -->
        <LinearLayout
            android:id="@+id/layoutBotones"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="20dp"
            app:layout_constraintTop_toBottomOf="@id/cardGrafica"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnIMC"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="IMC"
                android:textStyle="bold"
                android:textColor="#FF4B78"
                android:backgroundTint="@android:color/white"
                app:cornerRadius="25dp"
                app:strokeColor="#FF4B78"
                app:strokeWidth="2dp"/>

            <Space
                android:layout_width="12dp"
                android:layout_height="wrap_content"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVacuna"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="Agendar Vacuna"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:backgroundTint="#FF4B78"
                app:cornerRadius="25dp"
                app:icon="@android:drawable/ic_input_add"
                app:iconGravity="textEnd"/>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>